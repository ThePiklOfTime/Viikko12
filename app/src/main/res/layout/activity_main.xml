<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ReturnFromFightButton"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/Unimportant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monster Fighter"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.056" />

    <Button
        android:id="@+id/FightMonstersActivityButton"
        android:layout_width="149dp"
        android:layout_height="105dp"
        android:layout_marginTop="144dp"
        android:onClick="changeToFightMonstersActivity"
        android:text="Taistele hirvtiöitä vastaan"
        app:layout_constraintEnd_toEndOf="@+id/Unimportant"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="@+id/Unimportant"
        app:layout_constraintTop_toBottomOf="@+id/Unimportant" />

    <TextView
        android:id="@+id/PlayerScoreText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="108dp"
        android:text="Pisteet 0"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="@+id/FightMonstersActivityButton"
        app:layout_constraintStart_toStartOf="@+id/FightMonstersActivityButton"
        app:layout_constraintTop_toBottomOf="@+id/FightMonstersActivityButton" />

</androidx.constraintlayout.widget.ConstraintLayout>